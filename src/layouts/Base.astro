---
const { title = 'DSA Logger', activeTab = 'problems' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="my first blog to express and document my journey while learning Data Structures and Algorithms." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Syne:wght@400;500;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --font-sans: 'Syne', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
        --color-bg:        #fafaf9;
        --color-surface:   #f1efe8;
        --color-border:    rgba(0,0,0,0.1);
        --color-text:      #1a1a18;
        --color-muted:     #5f5e5a;
        --color-hint:      #888780;
        --color-easy:      #27500a;
        --color-easy-bg:   #eaf3de;
        --color-medium:    #633806;
        --color-medium-bg: #faeeda;
        --color-hard:      #791f1f;
        --color-hard-bg:   #fcebeb;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --color-bg:        #181816;
          --color-surface:   #222220;
          --color-border:    rgba(255,255,255,0.1);
          --color-text:      #e8e6df;
          --color-muted:     #b4b2a9;
          --color-hint:      #888780;
          --color-easy:      #97c459;
          --color-easy-bg:   #173404;
          --color-medium:    #ef9f27;
          --color-medium-bg: #412402;
          --color-hard:      #f09595;
          --color-hard-bg:   #501313;
        }
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { font-size: 16px; }

      body {
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.7;
        padding: 2rem 1.25rem;
      }

      a { color: var(--color-text); text-decoration: underline; text-underline-offset: 3px; }
      a:visited { color: var(--color-text); }
      a:hover { color: var(--color-muted); }

      /* ── Post-row hover highlight (used on index/uni/favourites pages) ── */
      :global(.post-row) {
        display: block;
        text-decoration: none;
        border-radius: 6px;
        padding: 0.6rem 0.75rem;
        margin: 0 -0.75rem;
        transition: background 0.12s;
      }
      :global(.post-row:visited) { color: var(--color-text); }
      :global(.post-row:hover)   { background: var(--color-surface); }

      /* ── Shell ── */
      .shell {
        max-width: 680px;
        margin: 0 auto;
      }

      /* ── Top bar ── */
      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
      }

      .logo {
        font-weight: 700;
        font-size: 15px;
        text-decoration: none;
      }
      .logo:hover { color: var(--color-muted); }

      /* ── Contact links ── */
      .contact-links {
        display: flex;
        align-items: center;
        gap: 1.25rem;
      }

      .contact-links a {
        font-size: 13px;
        color: var(--color-muted);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        transition: color 0.15s;
      }

      .contact-links a:hover { color: var(--color-text); }

      .contact-links svg {
        width: 14px;
        height: 14px;
        fill: currentColor;
        flex-shrink: 0;
      }

      /* ── Tab nav ── */
      .tab-nav {
        display: flex;
        border-bottom: 0.5px solid var(--color-border);
        margin-bottom: 2.5rem;
        overflow-x: auto;
        scrollbar-width: none;
      }

      .tab-nav::-webkit-scrollbar { display: none; }

      .tab {
        padding: 0.5rem 1rem;
        font-size: 13px;
        font-family: var(--font-mono);
        color: var(--color-hint);
        border-bottom: 1.5px solid transparent;
        margin-bottom: -0.5px;
        white-space: nowrap;
        transition: color 0.15s, border-color 0.15s;
        text-decoration: none;
      }

      .tab:hover { color: var(--color-muted); }

      .tab.active {
        color: var(--color-text);
        border-bottom-color: var(--color-text);
      }

      /* ── Shared global styles ── */
      :global(pre), :global(code) { font-family: var(--font-mono); }

      :global(pre) {
        background: var(--color-surface);
        border: 0.5px solid var(--color-border);
        border-radius: 8px;
        padding: 1rem 1.25rem;
        overflow-x: auto;
        font-size: 13px;
        line-height: 1.6;
        margin: 1.25rem 0;
      }

      :global(code) {
        font-size: 0.875em;
        background: var(--color-surface);
        padding: 1px 5px;
        border-radius: 4px;
      }

      :global(pre code) { background: none; padding: 0; font-size: inherit; }

      :global(p) { margin: 1rem 0; }

      :global(h1), :global(h2), :global(h3) { font-weight: 700; line-height: 1.3; margin: 1.5rem 0 0.5rem; }
      :global(h1) { font-size: 22px; }
      :global(h2) { font-size: 18px; }
      :global(h3) { font-size: 16px; }

      :global(hr) {
        border: none;
        border-top: 0.5px solid var(--color-border);
        margin: 2rem 0;
      }

      :global(ul), :global(ol) { padding-left: 1.5rem; margin: 1rem 0; }
      :global(li) { margin: 0.35rem 0; }

      :global(blockquote) {
        border-left: 2px solid var(--color-border);
        padding-left: 1rem;
        color: var(--color-muted);
        font-style: italic;
        margin: 1.25rem 0;
      }

      :global(strong) { font-weight: 700; }

      :global(.tag) {
        display: inline-block;
        font-size: 11px;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 20px;
        letter-spacing: 0.03em;
      }
      :global(.tag-easy)   { background: var(--color-easy-bg);   color: var(--color-easy); }
      :global(.tag-medium) { background: var(--color-medium-bg); color: var(--color-medium); }
      :global(.tag-hard)   { background: var(--color-hard-bg);   color: var(--color-hard); }
      :global(.tag-topic)  { background: var(--color-surface); color: var(--color-muted); border: 0.5px solid var(--color-border); }
      :global(.tag-uni)    { background: #ede9fe; color: #4c1d95; }
      :global(.tag-fav)    { background: #fff7ed; color: #7c2d12; }

      @media (prefers-color-scheme: dark) {
        :global(.tag-uni) { background: #2e1065; color: #c4b5fd; }
        :global(.tag-fav) { background: #431407; color: #fdba74; }
      }

      :global(.mono) { font-family: var(--font-mono); }
    </style>
  </head>
  <body>
    <div class="shell">

      <!-- Top bar -->
      <header class="topbar">
        <a href="/" class="logo">DSA log</a>
        <nav class="contact-links">
          <!-- GitHub -->
          <a href="https://github.com/YOUR_USERNAME" target="_blank" rel="noopener" title="GitHub">
            <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
                0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52
                -.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2
                -3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82
                .64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08
                2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01
                1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            GitHub
          </a>
          <!-- LinkedIn -->
          <a href="https://linkedin.com/in/YOUR_USERNAME" target="_blank" rel="noopener" title="LinkedIn">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853
                0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85
                3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0
                0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452z
                M22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451
                C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <!-- Email -->
          <a href="mailto:your@email.com" title="Email">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9
                2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            Email
          </a>
        </nav>
      </header>

      <!-- Tab navigation -->
      <nav class="tab-nav">
        <a href="/" class={`tab ${activeTab === 'problems' ? 'active' : ''}`}>all_problems</a>
        <a href="/about" class={`tab ${activeTab === 'about' ? 'active' : ''}`}>about.md</a>
      </nav>

      <!-- Page content -->
      <main class="page-content">
        <slot />
      </main>

    </div>
  </body>
</html>