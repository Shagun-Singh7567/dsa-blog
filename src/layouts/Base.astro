---
import '../styles/global.css';

const { title = 'DSA Logger' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="my first blog to express and document my journey while learning Data Structures and Algorithms." />
  </head>
  <body>
    <main>
      <nav style="display:flex; justify-content:space-between; align-items:center; margin-bottom:3rem;">
        <a href="/" style="font-weight:700; font-size:15px; text-decoration:none;">DSA log</a>
        <a href="/about" style="font-size:13px; color:var(--color-muted); text-decoration:none;">About</a>
      </nav>
      <slot />
    </main>
  </body>
</html>
