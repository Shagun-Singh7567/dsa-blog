---
import Base from './Base.astro';

const { frontmatter } = Astro.props;
const { title, day, date, difficulty, topics, timeComplexity, spaceComplexity } = frontmatter;

const dateStr = new Date(date).toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---
<Base title={`Day ${day} — ${title}`}>
  <header style="margin-bottom:2rem;">
    <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:0.75rem;">
      <span style="font-size:12px; font-family:var(--font-mono); color:var(--color-hint);">
        Day {String(day).padStart(3, '0')} — {dateStr}
      </span>
      <a href="/" style="font-size:12px; color:var(--color-muted); text-decoration:none;">← all problems</a>
    </div>

    <h1 style="margin:0 0 0.75rem;">{title}</h1>

    <div style="display:flex; flex-wrap:wrap; gap:6px; align-items:center;">
      <span class={`tag tag-${difficulty}`}>{difficulty}</span>
      {topics.map((t: string) => <span class="tag tag-topic">{t}</span>)}
    </div>

    <div style="display:flex; gap:1.5rem; margin-top:1rem; font-size:13px; color:var(--color-muted);">
      <span>Time <span class="mono" style="color:var(--color-text);">{timeComplexity}</span></span>
      <span>Space <span class="mono" style="color:var(--color-text);">{spaceComplexity}</span></span>
    </div>
  </header>

  <hr />

  <slot />

  <hr />
  <a href="/" style="font-size:13px; color:var(--color-muted); text-decoration:none;">← back to all problems</a>
</Base>
